<Window x:Class="MarkdownMidget.ExternalChangeDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="External Change Detected" SizeToContent="Height" Width="540"
        WindowStartupLocation="CenterOwner" ResizeMode="NoResize"
        ShowInTaskbar="False" Icon="/Assets/midget-256.png">
    <StackPanel Margin="18">
        <TextBlock x:Name="HeaderText" TextWrapping="Wrap" FontWeight="SemiBold" Margin="0,0,0,8" />
        <TextBlock Text="Your current version (including any unsaved edits) has been backed up to:"
                   TextWrapping="Wrap" Margin="0,0,0,4" />
        <TextBlock x:Name="BackupPathText" TextWrapping="Wrap" FontFamily="Consolas" FontSize="11"
                   Foreground="#444" Margin="0,0,0,14" />
        <TextBlock Text="What would you like to do?" Margin="0,0,0,10" />
        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
            <Button x:Name="ReloadBtn" Content="_Reload Disk Version" Width="160" Margin="0,0,8,0"
                    Click="Reload_Click" ToolTip="Discard your current view and load the new disk version." />
            <Button x:Name="SaveAsBtn" Content="_Save My Version As…" Width="160" Margin="0,0,8,0"
                    Click="SaveAs_Click" ToolTip="Save your current version under a chosen name, then decide." />
            <Button x:Name="KeepBtn" Content="_Keep Current" IsDefault="True" Width="110"
                    Click="Keep_Click" ToolTip="Don't reload. Your next Save will overwrite the disk version." />
        </StackPanel>
        <Button Content="Cancel" IsCancel="True" Visibility="Collapsed" />
    </StackPanel>
</Window>
