<Window x:Class="MarkdownMidget.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:wv2="clr-namespace:Microsoft.Web.WebView2.Wpf;assembly=Microsoft.Web.WebView2.Wpf"
        Title="Markdown Midget" Height="720" Width="1120"
        Icon="/Assets/midget-256.png"
        WindowStartupLocation="CenterScreen"
        AllowDrop="True" DragOver="Window_DragOver" Drop="Window_Drop">
    <Window.Resources>
        <!-- Old-school flat icon buttons (Notepad++-style), Segoe Fluent glyphs. -->
        <!-- Toolbar buttons never take focus, so clicking them can't move the
             document caret or drop the current text selection. -->
        <Style x:Key="ToolGlyph" TargetType="{x:Type ButtonBase}">
            <Setter Property="FontFamily" Value="Segoe Fluent Icons, Segoe MDL2 Assets" />
            <Setter Property="FontSize" Value="16" />
            <Setter Property="MinWidth" Value="30" />
            <Setter Property="Height" Value="26" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="Focusable" Value="False" />
            <Setter Property="IsTabStop" Value="False" />
        </Style>
        <!-- Buttons whose mark has no clean glyph; use a text symbol instead. -->
        <Style x:Key="ToolChar" TargetType="{x:Type ButtonBase}">
            <Setter Property="FontSize" Value="14" />
            <Setter Property="MinWidth" Value="30" />
            <Setter Property="Height" Value="26" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="Focusable" Value="False" />
            <Setter Property="IsTabStop" Value="False" />
        </Style>

        <!-- Native editor context menus (shown on right-click / Menu key in WYSIWYG). -->
        <ContextMenu x:Key="TableContextMenu" Opened="ContextMenu_Opened">
            <MenuItem Header="_Insert">
                <MenuItem Header="Column _Left" Tag="colLeft" Click="TableCmd_Click" />
                <MenuItem Header="Column _Right" Tag="colRight" Click="TableCmd_Click" />
                <MenuItem Header="Row _Above" Tag="rowAbove" Click="TableCmd_Click" />
                <MenuItem Header="Row _Below" Tag="rowBelow" Click="TableCmd_Click" />
            </MenuItem>
            <MenuItem Header="_Delete">
                <MenuItem Header="_Column" Tag="delCol" Click="TableCmd_Click" />
                <MenuItem Header="_Row" Tag="delRow" Click="TableCmd_Click" />
                <MenuItem Header="_Table" Tag="delTable" Click="TableCmd_Click" />
            </MenuItem>
            <MenuItem Header="_Select">
                <MenuItem Header="C_olumn" Tag="selCol" Click="TableCmd_Click" />
                <MenuItem Header="Ro_w" Tag="selRow" Click="TableCmd_Click" />
                <MenuItem Header="Ta_ble" Tag="selTable" Click="TableCmd_Click" />
            </MenuItem>
        </ContextMenu>
        <ContextMenu x:Key="ImageContextMenu" Opened="ContextMenu_Opened">
            <MenuItem Header="_Resize…" Click="ImageResize_Click" />
        </ContextMenu>
        <ContextMenu x:Key="TextContextMenu" Opened="ContextMenu_Opened">
            <MenuItem Header="Cu_t" Click="Cut_Click" />
            <MenuItem Header="_Copy" Click="Copy_Click" />
            <MenuItem Header="_Paste" Click="Paste_Click" />
            <Separator />
            <MenuItem Header="Select _All" Click="SelectAll_Click" />
        </ContextMenu>
    </Window.Resources>
    <DockPanel>
        <!-- ===== Top header: menu + toolbar on the left, mascot popped out at right ===== -->
        <Grid DockPanel.Dock="Top" Background="{x:Static SystemColors.ControlBrush}">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <StackPanel Grid.Column="0">
                <!-- ===== Menu bar (WordPad-style, MVP subset) ===== -->
                <Menu>
                    <MenuItem Header="_File" SubmenuOpened="FileMenu_Opened">
                        <MenuItem Header="_New" InputGestureText="Ctrl+N" Click="New_Click" />
                        <MenuItem Header="_Open…" InputGestureText="Ctrl+O" Click="Open_Click" />
                        <MenuItem x:Name="RecentMenu" Header="Open _Recent" />
                        <Separator />
                        <MenuItem x:Name="SaveMenu" Header="_Save" InputGestureText="Ctrl+S" Click="Save_Click" />
                        <MenuItem Header="Save _As…" InputGestureText="Ctrl+Shift+S" Click="SaveAs_Click" />
                        <Separator />
                        <MenuItem Header="E_xit" Click="Exit_Click" />
                    </MenuItem>
                    <MenuItem Header="_Edit">
                        <MenuItem x:Name="UndoMenu" Header="_Undo" InputGestureText="Ctrl+Z" Click="Undo_Click" />
                        <MenuItem x:Name="RedoMenu" Header="_Redo" InputGestureText="Ctrl+Y" Click="Redo_Click" />
                        <Separator />
                        <MenuItem Header="Cu_t" InputGestureText="Ctrl+X" Click="Cut_Click" />
                        <MenuItem Header="_Copy" InputGestureText="Ctrl+C" Click="Copy_Click" />
                        <MenuItem Header="_Paste" InputGestureText="Ctrl+V" Click="Paste_Click" />
                        <Separator />
                        <MenuItem Header="Select _All" InputGestureText="Ctrl+A" Click="SelectAll_Click" />
                        <Separator />
                        <MenuItem x:Name="MenuReadOnly" Header="_Read Only"
                                  IsCheckable="True" Click="ReadOnly_Click" />
                    </MenuItem>
                    <MenuItem x:Name="FormatMenu" Header="F_ormat">
                        <MenuItem Header="_Bold" InputGestureText="Ctrl+B" Click="Bold_Click" />
                        <MenuItem Header="_Italic" InputGestureText="Ctrl+I" Click="Italic_Click" />
                        <MenuItem Header="_Underline" InputGestureText="Ctrl+U" Click="Underline_Click" />
                        <MenuItem Header="_Strikethrough" Click="Strike_Click" />
                        <MenuItem Header="Inline _Code" Click="Code_Click" />
                        <Separator />
                        <MenuItem Header="Bulleted _List" Click="Bullet_Click" />
                        <MenuItem Header="_Numbered List" Click="Ordered_Click" />
                        <MenuItem Header="Block _Quote" Click="Quote_Click" />
                        <MenuItem Header="_Horizontal Rule" Click="Hr_Click" />
                    </MenuItem>
                    <MenuItem x:Name="StyleMenu" Header="St_yle">
                        <MenuItem Header="_Paragraph" InputGestureText="Ctrl+0" Click="Style_Click" Tag="paragraph" />
                        <Separator />
                        <MenuItem Header="Heading _1" InputGestureText="Ctrl+1" Click="Style_Click" Tag="h1" />
                        <MenuItem Header="Heading _2" InputGestureText="Ctrl+2" Click="Style_Click" Tag="h2" />
                        <MenuItem Header="Heading _3" InputGestureText="Ctrl+3" Click="Style_Click" Tag="h3" />
                        <MenuItem Header="Heading _4" InputGestureText="Ctrl+4" Click="Style_Click" Tag="h4" />
                        <MenuItem Header="Heading _5" InputGestureText="Ctrl+5" Click="Style_Click" Tag="h5" />
                        <Separator />
                        <MenuItem Header="_Code Block">
                            <MenuItem Header="Plain" Tag="" Click="CodeBlock_Click" />
                            <Separator />
                            <MenuItem Header="C#" Tag="csharp" Click="CodeBlock_Click" />
                            <MenuItem Header="JavaScript" Tag="javascript" Click="CodeBlock_Click" />
                            <MenuItem Header="TypeScript" Tag="typescript" Click="CodeBlock_Click" />
                            <MenuItem Header="HTML" Tag="html" Click="CodeBlock_Click" />
                            <MenuItem Header="CSS" Tag="css" Click="CodeBlock_Click" />
                        </MenuItem>
                        <Separator />
                        <MenuItem Header="_Focus Style Box" InputGestureText="Ctrl+Shift+H" Click="FocusStyle_Click" />
                    </MenuItem>
                    <MenuItem x:Name="InsertMenu" Header="_Insert">
                        <MenuItem Header="_Link…" InputGestureText="Ctrl+K" Click="Link_Click" />
                        <MenuItem Header="_Picture…" Click="Picture_Click" />
                        <MenuItem Header="_Table…" Click="InsertTable_Click" />
                        <Separator />
                        <MenuItem Header="_Code Block">
                            <MenuItem Header="Plain" Tag="" Click="CodeBlock_Click" />
                            <Separator />
                            <MenuItem Header="C#" Tag="csharp" Click="CodeBlock_Click" />
                            <MenuItem Header="JavaScript" Tag="javascript" Click="CodeBlock_Click" />
                            <MenuItem Header="TypeScript" Tag="typescript" Click="CodeBlock_Click" />
                            <MenuItem Header="HTML" Tag="html" Click="CodeBlock_Click" />
                            <MenuItem Header="CSS" Tag="css" Click="CodeBlock_Click" />
                        </MenuItem>
                    </MenuItem>
                    <MenuItem Header="_View">
                        <MenuItem x:Name="MenuViewSource" Header="Edit Markdown _Source"
                                  IsCheckable="True" InputGestureText="Ctrl+E" Click="ToggleSource_Click" />
                        <Separator />
                        <MenuItem Header="Document _Width">
                            <MenuItem x:Name="PageWidthPortrait" Header="_Portrait" IsCheckable="True"
                                      Tag="portrait" Click="PageWidth_Click" />
                            <MenuItem x:Name="PageWidthLandscape" Header="_Landscape" IsCheckable="True"
                                      Tag="landscape" Click="PageWidth_Click" />
                            <MenuItem x:Name="PageWidthFull" Header="_Full Width" IsCheckable="True"
                                      Tag="full" Click="PageWidth_Click" />
                        </MenuItem>
                        <Separator />
                        <MenuItem x:Name="MenuSpellCheck" Header="_Spell Check"
                                  IsCheckable="True" IsChecked="True" Click="SpellCheck_Click" />
                    </MenuItem>
                    <MenuItem Header="_Help">
                        <MenuItem x:Name="MenuViewHelp" Header="_View Help" Click="Help_Click" />
                        <Separator />
                        <MenuItem Header="_About Markdown Midget" Click="About_Click" />
                    </MenuItem>
                </Menu>

                <!-- ===== Toolbar (File / Format / View groups) ===== -->
                <ToolBarTray IsLocked="True">
                    <!-- File + history: stays usable in read-only (Save As included). -->
                    <ToolBar Band="0" BandIndex="0">
                        <Button Style="{StaticResource ToolGlyph}" ToolTip="New (Ctrl+N)" Click="New_Click" Content="&#xE7C3;" />
                        <Button Style="{StaticResource ToolGlyph}" ToolTip="Open (Ctrl+O)" Click="Open_Click" Content="&#xED25;" />
                        <Button x:Name="SaveBtn" Style="{StaticResource ToolGlyph}" ToolTip="Save (Ctrl+S)" Click="Save_Click" Content="&#xE74E;" />
                        <Button Style="{StaticResource ToolGlyph}" ToolTip="Save As… (Ctrl+Shift+S)" Click="SaveAs_Click" Content="&#xEA35;" />
                        <Separator />
                        <Button x:Name="UndoBtn" Style="{StaticResource ToolGlyph}" ToolTip="Undo (Ctrl+Z)" Click="Undo_Click" Content="&#xE7A7;" />
                        <Button x:Name="RedoBtn" Style="{StaticResource ToolGlyph}" ToolTip="Redo (Ctrl+Y)" Click="Redo_Click" Content="&#xE7A6;" />
                    </ToolBar>

                    <!-- Formatting: disabled wholesale in read-only mode. -->
                    <ToolBar x:Name="FormatToolBar" Band="0" BandIndex="1">
                        <!-- Paragraph style: replaces WordPad's font-size box ("Styles, not size"). -->
                        <TextBlock Text="Style:" VerticalAlignment="Center" Margin="4,0,4,0" />
                        <ComboBox x:Name="StyleCombo" Width="162" IsTabStop="False"
                                  ToolTip="Block style (Ctrl+Shift+H)"
                                  SelectionChanged="StyleCombo_Changed">
                            <ComboBoxItem Content="Paragraph" Tag="paragraph" IsSelected="True" />
                            <ComboBoxItem Content="H1 &#8212; Heading 1" Tag="h1" />
                            <ComboBoxItem Content="H2 &#8212; Heading 2" Tag="h2" />
                            <ComboBoxItem Content="H3 &#8212; Heading 3" Tag="h3" />
                            <ComboBoxItem Content="H4 &#8212; Heading 4" Tag="h4" />
                            <ComboBoxItem Content="H5 &#8212; Heading 5" Tag="h5" />
                            <Separator />
                            <ComboBoxItem Content="Code: Plain" Tag="codeblock:" />
                            <ComboBoxItem Content="Code: C#" Tag="codeblock:csharp" />
                            <ComboBoxItem Content="Code: JavaScript" Tag="codeblock:javascript" />
                            <ComboBoxItem Content="Code: TypeScript" Tag="codeblock:typescript" />
                            <ComboBoxItem Content="Code: HTML" Tag="codeblock:html" />
                            <ComboBoxItem Content="Code: CSS" Tag="codeblock:css" />
                        </ComboBox>
                        <Separator />
                        <Button Style="{StaticResource ToolGlyph}" ToolTip="Bold (Ctrl+B)" Click="Bold_Click" Content="&#xE8DD;" />
                        <Button Style="{StaticResource ToolGlyph}" ToolTip="Italic (Ctrl+I)" Click="Italic_Click" Content="&#xE8DB;" />
                        <Button Style="{StaticResource ToolGlyph}" ToolTip="Underline (Ctrl+U)" Click="Underline_Click" Content="&#xE8DC;" />
                        <Button Style="{StaticResource ToolGlyph}" ToolTip="Strikethrough" Click="Strike_Click" Content="&#xEDE0;" />
                        <!-- Hybrid code button: main click = inline code, chevron = code block language. -->
                        <Button Style="{StaticResource ToolChar}" ToolTip="Inline code" Click="Code_Click" FontFamily="Consolas" Content="&lt;/&gt;" />
                        <Button Style="{StaticResource ToolGlyph}" ToolTip="Code block…" Click="CodeBlockMenu_Click"
                                MinWidth="16" FontSize="10" Content="&#xE70D;">
                            <Button.ContextMenu>
                                <ContextMenu>
                                    <MenuItem Header="Plain" Tag="" Click="CodeBlock_Click" />
                                    <Separator />
                                    <MenuItem Header="C#" Tag="csharp" Click="CodeBlock_Click" />
                                    <MenuItem Header="JavaScript" Tag="javascript" Click="CodeBlock_Click" />
                                    <MenuItem Header="TypeScript" Tag="typescript" Click="CodeBlock_Click" />
                                    <MenuItem Header="HTML" Tag="html" Click="CodeBlock_Click" />
                                    <MenuItem Header="CSS" Tag="css" Click="CodeBlock_Click" />
                                </ContextMenu>
                            </Button.ContextMenu>
                        </Button>
                        <Separator />
                        <Button Style="{StaticResource ToolGlyph}" ToolTip="Bulleted list" Click="Bullet_Click" Content="&#xE8FD;" />
                        <Button Style="{StaticResource ToolGlyph}" ToolTip="Numbered list" Click="Ordered_Click">
                            <Image Source="/Assets/numbered-list-64.png" Width="16" Height="16"
                                   RenderOptions.BitmapScalingMode="HighQuality" />
                        </Button>
                        <Button Style="{StaticResource ToolChar}" ToolTip="Block quote" Click="Quote_Click" FontSize="18" Content="&#x275D;" />
                        <Button Style="{StaticResource ToolGlyph}" ToolTip="Horizontal rule" Click="Hr_Click" Content="&#xE738;" />
                        <Separator />
                        <Button Style="{StaticResource ToolGlyph}" ToolTip="Insert link (Ctrl+K)" Click="Link_Click" Content="&#xE71B;" />
                        <Button Style="{StaticResource ToolGlyph}" ToolTip="Insert picture" Click="Picture_Click" Content="&#xEB9F;" />
                        <Button Style="{StaticResource ToolGlyph}" ToolTip="Insert table" Click="InsertTable_Click" Content="&#xE80A;" />
                    </ToolBar>

                    <!-- View toggles: usable in read-only. -->
                    <ToolBar Band="0" BandIndex="2">
                        <ToggleButton x:Name="SourceToggle" Style="{StaticResource ToolGlyph}"
                                      ToolTip="Edit markdown source (Ctrl+E)"
                                      Click="ToggleSource_Click" />
                        <ToggleButton x:Name="MarksToggle" Style="{StaticResource ToolChar}"
                                      ToolTip="Show formatting marks (¶)"
                                      Click="ToggleMarks_Click" FontSize="15" Content="&#xB6;" />
                    </ToolBar>
                </ToolBarTray>
            </StackPanel>

            <Image Grid.Column="1" Source="/Assets/midget-256.png"
                   Width="52" Height="52" Margin="10,2,16,2" VerticalAlignment="Center"
                   ToolTip="Markdown Midget" RenderOptions.BitmapScalingMode="HighQuality" />
        </Grid>

        <!-- ===== Status bar ===== -->
        <StatusBar DockPanel.Dock="Bottom">
            <StatusBar.ItemsPanel>
                <ItemsPanelTemplate>
                    <DockPanel HorizontalAlignment="Stretch" />
                </ItemsPanelTemplate>
            </StatusBar.ItemsPanel>
            <StatusBarItem>
                <TextBlock x:Name="StatusMode" Text="WYSIWYG" />
            </StatusBarItem>
            <Separator />
            <StatusBarItem>
                <TextBlock x:Name="StatusFile" Text="Untitled" />
            </StatusBarItem>
            <StatusBarItem DockPanel.Dock="Right">
                <TextBlock x:Name="StatusZoom" Text="100%" ToolTip="Zoom (Ctrl+scroll). Click to reset."
                           Cursor="Hand" MouseLeftButtonUp="StatusZoom_Reset" Margin="0,0,6,0" />
            </StatusBarItem>
        </StatusBar>

        <!-- ===== Editing surface: WebView (WYSIWYG) over a raw-markdown box ===== -->
        <Grid>
            <wv2:WebView2 x:Name="Web" />
            <TextBox x:Name="SourceBox"
                     Visibility="Collapsed"
                     TextChanged="Source_TextChanged"
                     AcceptsReturn="True" AcceptsTab="True"
                     TextWrapping="NoWrap"
                     VerticalScrollBarVisibility="Auto"
                     HorizontalScrollBarVisibility="Auto"
                     FontFamily="Consolas" FontSize="14"
                     Padding="12"
                     Background="#FFFBFBFB" />
        </Grid>
    </DockPanel>
</Window>
