<Window x:Class="MarkdownMidget.InputDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Insert" SizeToContent="Height" Width="420"
        WindowStartupLocation="CenterOwner" ResizeMode="NoResize"
        ShowInTaskbar="False" Icon="/Assets/midget-256.png">
    <StackPanel Margin="16">
        <TextBlock x:Name="Label1" Text="Text" Margin="0,0,0,4" />
        <TextBox x:Name="Field1" Margin="0,0,0,12" Padding="3" />
        <TextBlock x:Name="Label2" Text="URL" Margin="0,0,0,4" />
        <TextBox x:Name="Field2" Margin="0,0,0,16" Padding="3" />
        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="OK" IsDefault="True" Width="80" Margin="0,0,8,0" Click="Ok_Click" />
            <Button Content="Cancel" IsCancel="True" Width="80" />
        </StackPanel>
    </StackPanel>
</Window>
