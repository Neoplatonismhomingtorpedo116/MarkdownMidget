<?xml version="1.0" encoding="utf-8"?>
<!--
  Smaller, framework-dependent single-file build for testers who already have the
  .NET 10 Desktop runtime installed (plus the Edge WebView2 runtime). A few MB
  instead of ~63 MB, since the .NET runtime is NOT bundled.

  Publish with:  dotnet publish src/MarkdownMidget -p:PublishProfile=win-x64-fxdependent
  Output:        src/MarkdownMidget/bin/Release/net10.0-windows/win-x64/publish/MarkdownMidget.exe

  Use win-x64.pubxml instead for the fully self-contained (no prerequisites) build.
-->
<Project>
  <PropertyGroup>
    <Configuration>Release</Configuration>
    <Platform>Any CPU</Platform>
    <PublishDir>bin\Release\publish\framework-dependent\</PublishDir>
    <RuntimeIdentifier>win-x64</RuntimeIdentifier>
    <SelfContained>false</SelfContained>
    <PublishSingleFile>true</PublishSingleFile>
    <IncludeNativeLibrariesForSelfExtract>true</IncludeNativeLibrariesForSelfExtract>
    <DebugType>embedded</DebugType>
    <PublishReferencesDocumentationFiles>false</PublishReferencesDocumentationFiles>
    <AllowedReferenceRelatedFileExtensions>none</AllowedReferenceRelatedFileExtensions>
  </PropertyGroup>
</Project>
